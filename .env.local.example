# Supabase — get these from: Supabase dashboard → Project Settings → API Keys
# Use the new "Publishable" key (sb_publishable_...), not the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Resend (for email notifications) — get from: resend.com → API Keys
# Not required for initial development; add when implementing notifications
RESEND_API_KEY=re_...
